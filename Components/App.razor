<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CookBook 🍽️</title>
    <base href="/" />
    <link rel="stylesheet" href="/app.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        window.renderChart = (id, type, labels, data, label, colors) => {
            const ctx = document.getElementById(id);
            if (!ctx) return;
            
            const existing = Chart.getChart(id);
            if (existing) existing.destroy();

            const isLine = type === 'line';
            const isBar = type === 'bar';

            new Chart(ctx, {
                type: type,
                data: {
                    labels: labels,
                    datasets: [{
                        label: label,
                        data: data,
                        backgroundColor: isLine ? 'rgba(255, 107, 53, 0.2)' : colors,
                        borderColor: isLine ? '#FF6B35' : colors,
                        hoverBackgroundColor: isBar ? '#FFB84D' : colors,
                        borderWidth: isLine ? 3 : 1,
                        tension: 0.4,
                        fill: isLine,
                        pointBackgroundColor: '#FF6B35',
                        pointRadius: isLine ? 4 : 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            display: type !== 'bar' && type !== 'line',
                            position: 'bottom',
                            labels: { color: '#E0E7FF', font: { size: 12, family: 'Inter' }, padding: 20 } 
                        },
                        tooltip: { backgroundColor: '#1A2332', titleColor: '#E0E7FF', bodyColor: '#E0E7FF', cornerRadius: 8 }
                    },
                    scales: (isBar || isLine) ? {
                        y: { 
                            beginAtZero: true,
                            ticks: { color: '#E0E7FF', font: { family: 'Inter' } }, 
                            grid: { color: 'rgba(224, 231, 255, 0.05)' } 
                        },
                        x: { 
                            ticks: { color: '#E0E7FF', font: { family: 'Inter' } }, 
                            grid: { display: false } 
                        }
                    } : {}
                }
            });
        };
    </script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>