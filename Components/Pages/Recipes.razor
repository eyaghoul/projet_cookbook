@page "/recipes"
@rendermode InteractiveServer
@inject IRecipeService RecipeService
@inject ICategoryService CategoryService
@inject IIngredientService IngredientService
@inject IUnitService UnitService
@inject ITypeCuisineService TypeCuisineService
@inject IJSRuntime JSRuntime

<style>
    .add-recipe-section { display: flex; justify-content: flex-end; margin-bottom: 16px; }
    .recipe-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; margin-bottom: 2rem; }
</style>

<div class="page-header">
    <div>
        <h1>Recipes</h1>
        <p class="subtitle">Filter your recipes in real time and rate your favorites.</p>
    </div>
</div>

@if (isLoading)
{
    <p><em>Loading recipes...</em></p>
}
else
{
    <div class="add-recipe-section">
        <button class="btn btn-primary" @onclick="OpenAddRecipeModal">+ Add Recipe</button>
    </div>

    <RecipeFilterBar UniversalSearch="@universalSearch"
                     UniversalSearchChanged="@(v => { universalSearch = v; StateHasChanged(); })"
                     SelectedCategory="@selectedCategory"
                     SelectedCategoryChanged="@(v => { selectedCategory = v; StateHasChanged(); })"
                     Categories="@categories" OnReset="ResetFilters" />

    @if (!FilteredRecipes.Any())
    {
        <div class="empty-state">
            <h2>No recipes match the filters.</h2>
            <p>Try resetting the filters or changing your search criteria.</p>
        </div>
    }
    else
    {
        <div class="recipe-grid">
            @foreach (var recipe in FilteredRecipes)
            {
                <RecipeCard Recipe="recipe"
                            CurrentRating="GetCurrentRating(recipe.Id)"
                            HoverRating="@(hoverRatings.TryGetValue(recipe.Id, out var h) ? h : 0)"
                            AverageRating="GetAverageRating(recipe.Id)"
                            VoteCount="GetVoteCount(recipe.Id)"
                            OnClick="OpenRecipeDetails"
                            OnEdit="OpenEditRecipeModal"
                            OnDelete="DeleteRecipe"
                            OnRate="@(star => RateRecipe(recipe.Id, star))"
                            OnHover="@(star => SetHover(recipe.Id, star))"
                            OnHoverOut="@(() => ClearHover(recipe.Id))" />
            }
        </div>
    }

    @if (showRecipeDetails && selectedRecipe is not null)
    {
        <RecipeDetails Recipe="selectedRecipe" AverageRating="selectedRecipeAverageRating" OnClose="CloseRecipeDetails" />
    }

    <RecipeFormModal IsVisible="showAddRecipeModal" IsEditMode="isEditMode"
                     RecipeName="@recipeName" RecipeNameChanged="@(v => recipeName = v)"
                     SelectedCategoryForm="@selectedCategoryForm" SelectedCategoryFormChanged="@(v => selectedCategoryForm = v)"
                     SelectedTypeCuisine="@selectedTypeCuisine" SelectedTypeCuisineChanged="@(v => selectedTypeCuisine = v)"
                     NumberOfPersons="@numberOfPersons" NumberOfPersonsChanged="@(v => numberOfPersons = v)"
                     CaloriesPerPerson="@caloriesPerPerson" CaloriesPerPersonChanged="@(v => caloriesPerPerson = v)"
                     Instructions="@instructions" InstructionsChanged="@(v => instructions = v)"
                     ImagePreview="@imagePreview"
                     Categories="@categories" TypeCuisines="@typeCuisines"
                     AllIngredients="@allIngredients" Units="@units"
                     Ingredients="@ingredients" HasError="@hasError" ErrorMessage="@errorMessage"
                     OnSave="SaveRecipe" OnCancel="CloseModal" OnBackdropClick="CloseModal"
                     OnAddIngredient="AddIngredient" OnRemoveIngredient="RemoveIngredient"
                     OnFileChange="HandleFileChange" />
}

@code {
    private bool isLoading = true;
    private List<Recipe> recipes = new();
    private List<Category> categories = new();
    private List<Ingredient> allIngredients = new();
    private List<Unit> units = new();
    private List<TypeCuisine> typeCuisines = new();
    private string universalSearch = string.Empty;
    private string selectedCategory = "All";
    private readonly Dictionary<int, RatingRecord> ratings = new();
    private readonly Dictionary<int, int> hoverRatings = new();

    // Modal state
    private bool showAddRecipeModal, showRecipeDetails, isEditMode, hasError;
    private int editingRecipeId;
    private Recipe? selectedRecipe;
    private double selectedRecipeAverageRating;
    private string recipeName = "", selectedCategoryForm = "", selectedTypeCuisine = "";
    private string instructions = "", imagePreview = "", errorMessage = "";
    private int numberOfPersons = 1;
    private double caloriesPerPerson;
    private IBrowserFile? uploadedFile;
    private List<IngredientRow> ingredients = new();

    private IEnumerable<Recipe> FilteredRecipes => recipes
        .Where(r =>
        {
            if (string.IsNullOrWhiteSpace(universalSearch)) return true;
            if (int.TryParse(universalSearch.Trim(), out var cal)) return Math.Abs(r.CaloriesPerPerson - cal) <= 50;
            return r.Name.Contains(universalSearch, StringComparison.OrdinalIgnoreCase) ||
                   r.RecipeIngredients.Any(ri => ri.Ingredient?.Name?.Contains(universalSearch, StringComparison.OrdinalIgnoreCase) == true);
        })
        .Where(r => selectedCategory == "All" || string.Equals(r.Category?.Name, selectedCategory, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnInitializedAsync() { await LoadData(); isLoading = false; }

    private async Task LoadData()
    {
        recipes = await RecipeService.GetAllAsync();
        categories = await CategoryService.GetAllAsync();
        allIngredients = await IngredientService.GetAllAsync();
        units = await UnitService.GetAllAsync();
        typeCuisines = await TypeCuisineService.GetAllAsync();
        ResetForm();
    }

    // Ratings
    private void SetHover(int id, int star) => hoverRatings[id] = star;
    private void ClearHover(int id) => hoverRatings[id] = 0;
    private int GetVoteCount(int id) => ratings.TryGetValue(id, out var r) ? r.Votes : 0;
    private double GetAverageRating(int id) => ratings.TryGetValue(id, out var r) && r.Votes > 0 ? Math.Round(r.Sum / (double)r.Votes, 1) : 0;
    private int GetCurrentRating(int id) => ratings.TryGetValue(id, out var r) && r.Votes > 0 ? (int)Math.Round(r.Sum / (double)r.Votes) : 0;
    private void RateRecipe(int id, int star)
    {
        if (!ratings.TryGetValue(id, out var rec)) { rec = new RatingRecord(); ratings[id] = rec; }
        rec.Votes++; rec.Sum += star;
    }

    // Ingredients
    private void AddIngredient() => ingredients.Add(new IngredientRow());
    private void RemoveIngredient(int i) { if (i >= 0 && i < ingredients.Count) ingredients.RemoveAt(i); }
    private async Task HandleFileChange(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
        if (uploadedFile is not null)
        {
            using var stream = uploadedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var bytes = new byte[uploadedFile.Size];
            await stream.ReadAsync(bytes);
            imagePreview = $"data:{uploadedFile.ContentType};base64,{Convert.ToBase64String(bytes)}";
        }
    }

    // Modal
    private void OpenAddRecipeModal() { isEditMode = false; editingRecipeId = 0; showAddRecipeModal = true; ResetForm(); }
    private void CloseModal() { showAddRecipeModal = false; ResetForm(); }
    private void ResetFilters() { universalSearch = string.Empty; selectedCategory = "All"; }
    private void CloseRecipeDetails() { showRecipeDetails = false; selectedRecipe = null; }
    private void OpenRecipeDetails(Recipe recipe)
    {
        selectedRecipe = recipe;
        selectedRecipeAverageRating = GetAverageRating(recipe.Id);
        showRecipeDetails = true;
    }
    private void OpenEditRecipeModal(Recipe recipe)
    {
        isEditMode = true; editingRecipeId = recipe.Id;
        recipeName = recipe.Name;
        selectedCategoryForm = recipe.Category?.Name ?? categories.FirstOrDefault()?.Name ?? "";
        selectedTypeCuisine = recipe.TypeCuisine?.Name ?? typeCuisines.FirstOrDefault()?.Name ?? "";
        numberOfPersons = recipe.NumberOfPersons;
        caloriesPerPerson = recipe.CaloriesPerPerson;
        instructions = recipe.CookingMethod;
        imagePreview = recipe.ImageUrl ?? string.Empty;
        ingredients = recipe.RecipeIngredients.Select(ri => new IngredientRow
        {
            IngredientName = ri.Ingredient?.Name ?? "",
            Quantity = ri.Quantity,
            UnitAbbreviation = ri.Unit?.Abbreviation ?? ""
        }).ToList();
        showAddRecipeModal = true;
    }
    private async Task DeleteRecipe(int id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this recipe?")) return;
        await RecipeService.DeleteAsync(id);
        recipes.RemoveAll(r => r.Id == id);
    }
    private async Task SaveRecipe()
    {
        hasError = false;
        if (string.IsNullOrWhiteSpace(recipeName)) { hasError = true; errorMessage = "Recipe name is required."; return; }
        if (!ingredients.Any(i => !string.IsNullOrWhiteSpace(i.IngredientName))) { hasError = true; errorMessage = "At least one ingredient is required."; return; }

        var category = categories.FirstOrDefault(c => c.Name == selectedCategoryForm) ?? new Category { Name = selectedCategoryForm };
        var typeCuisine = typeCuisines.FirstOrDefault(t => t.Name == selectedTypeCuisine) ?? new TypeCuisine { Name = selectedTypeCuisine };
        var recipeIngredients = ingredients
            .Where(i => !string.IsNullOrWhiteSpace(i.IngredientName))
            .Select(i => new RecipeIngredient
            {
                Ingredient = allIngredients.First(ing => ing.Name == i.IngredientName),
                Quantity = i.Quantity,
                Unit = units.FirstOrDefault(u => u.Abbreviation == i.UnitAbbreviation)
            }).ToList();

        var toSave = new Recipe
        {
            Id = editingRecipeId, Name = recipeName, Category = category, TypeCuisine = typeCuisine,
            NumberOfPersons = numberOfPersons, CookingMethod = instructions,
            ImageUrl = imagePreview, RecipeIngredients = new List<RecipeIngredient>()
        };

        if (isEditMode && editingRecipeId > 0)
        {
            await RecipeService.UpdateAsync(toSave, recipeIngredients);
            var idx = recipes.FindIndex(r => r.Id == editingRecipeId);
            if (idx >= 0) recipes[idx] = toSave;
        }
        else
        {
            await RecipeService.AddAsync(toSave, recipeIngredients);
            recipes.Add(toSave);
        }
        showAddRecipeModal = false; isEditMode = false; editingRecipeId = 0; ResetForm();
    }
    private void ResetForm()
    {
        recipeName = ""; selectedCategoryForm = ""; selectedTypeCuisine = "";
        numberOfPersons = 1; caloriesPerPerson = 0;
        instructions = ""; imagePreview = ""; uploadedFile = null;
        ingredients.Clear(); hasError = false; errorMessage = "";
    }

    private class RatingRecord { public int Votes { get; set; } public int Sum { get; set; } }
}
