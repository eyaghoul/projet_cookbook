@page "/"
@page "/dashboard"
@using CookBook.Models
@using CookBook.Services.Interfaces
@inject IRecipeService RecipeService
@inject IIngredientService IngredientService
@inject IJSRuntime JS

@rendermode InteractiveServer

<div class="page-header">
    <div class="header-with-actions">
        <div>
            <h1>Dashboard</h1>
            <p class="subtitle">Statistics and overview of your cookbook</p>
        </div>
        <button class="btn btn-secondary" @onclick="RefreshData">
            <i class="fas fa-sync-alt"></i> Refresh Data
        </button>
    </div>
</div>

@if (recipes == null)
{
    <div class="loading-state">
        <div class="spinner"></div>
        <p>Loading statistics...</p>
    </div>
}
else if (!recipes.Any())
{
    <div class="no-data-card">
        <i class="fas fa-chart-pie"></i>
        <h3>No data available</h3>
    </div>
}
else
{
    <div class="metrics-grid">
        <div class="metric-card">
            <span class="metric-value">@totalRecipes</span>
            <span class="metric-label">Total Recipes</span>
        </div>
        <div class="metric-card">
            <span class="metric-value">@totalIngredients</span>
            <span class="metric-label">Total Ingredients</span>
        </div>
        <div class="metric-card">
            <span class="metric-value">@avgRating.ToString("0.0") ★</span>
            <span class="metric-label">Average Rating</span>
        </div>
        <div class="metric-card">
            <span class="metric-value">@maxCals.ToString("0")</span>
            <span class="metric-label">Max Calories</span>
        </div>
        <div class="metric-card">
            <span class="metric-value">@minCals.ToString("0")</span>
            <span class="metric-label">Min Calories</span>
        </div>
    </div>

    <div class="charts-grid">
        <div class="chart-container">
            <h3>Calories Distribution</h3>
            <div class="canvas-wrapper"><canvas id="caloriesPie"></canvas></div>
        </div>
        <div class="chart-container">
            <h3>Recipe Distribution</h3>
            <div class="canvas-wrapper"><canvas id="categoryPie"></canvas></div>
        </div>
        <div class="chart-container">
            <h3>Type of Cuisine Distribution</h3>
            <div class="canvas-wrapper"><canvas id="cuisineBar"></canvas></div>
        </div>
        <div class="chart-container">
            <h3>Average Calories per Category</h3>
            <div class="canvas-wrapper"><canvas id="categoryLine"></canvas></div>
        </div>
    </div>
}

<style>
    .header-with-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        margin-bottom: 1rem;
    }

    .loading-state, .no-data-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 18px;
        padding: 4rem 2rem;
        text-align: center;
        margin-top: 2rem;
    }

    .no-data-card i {
        font-size: 4rem;
        color: var(--primary);
        margin-bottom: 1.5rem;
        opacity: 0.5;
    }

    .no-data-card h3 { margin-bottom: 1rem; color: var(--text); }
    .no-data-card p { color: var(--text-light); margin-bottom: 2rem; }

    .metrics-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    .metric-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 18px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        transition: transform 0.3s ease;
    }

    .metric-card:hover { transform: translateY(-5px); }

    .metric-value {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--primary);
        margin-bottom: 0.25rem;
    }

    .metric-label {
        font-size: 0.8rem;
        color: var(--text-light);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .charts-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }

    .chart-container {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 18px;
        padding: 1.5rem;
        min-height: 350px;
        display: flex;
        flex-direction: column;
    }

    .chart-container h3 {
        margin-top: 0;
        margin-bottom: 1.5rem;
        font-size: 1.1rem;
        color: var(--text);
        text-align: center;
    }

    .canvas-wrapper {
        flex: 1;
        position: relative;
    }

    @@media (max-width: 1200px) {
        .metrics-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 768px) {
        .charts-grid, .metrics-grid { grid-template-columns: 1fr; }
    }
</style>

@code {
    private int totalRecipes, totalIngredients;
    private double avgRating = 4.5, maxCals, minCals;
    private List<Recipe>? recipes;
    private bool chartsInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        recipes = await RecipeService.GetAllAsync();
        var allIngs = await IngredientService.GetAllAsync();
        
        totalRecipes = recipes.Count;
        totalIngredients = allIngs.Count;
        
        if (recipes.Any())
        {
            maxCals = recipes.Max(r => r.CaloriesPerPerson);
            minCals = recipes.Min(r => r.CaloriesPerPerson);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (recipes != null && recipes.Any() && !chartsInitialized)
        {
            // Small delay to ensure the DOM is fully ready after the @else block renders
            await Task.Delay(200);
            try 
            {
                await RenderCharts();
                chartsInitialized = true;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Dashboard Chart Error: {ex.Message}");
            }
        }
    }

    private async Task RefreshData()
    {
        recipes = null;
        chartsInitialized = false;
        await OnInitializedAsync();
        StateHasChanged();
    }

    private async Task RenderCharts()
    {
        if (recipes == null || !recipes.Any()) return;
        
        // 1. Calories Distribution (Pie)
        var low = recipes.Count(r => r.CaloriesPerPerson < 300);
        var med = recipes.Count(r => r.CaloriesPerPerson >= 300 && r.CaloriesPerPerson <= 600);
        var high = recipes.Count(r => r.CaloriesPerPerson > 600);
        await JS.InvokeVoidAsync("renderChart", "caloriesPie", "pie", 
            new[] { "Low (<300)", "Medium (300-600)", "High (>600)" }, 
            new[] { low, med, high }, "Calories", 
            new[] { "#26C281", "#FFB84D", "#FF4757" }); // Green, Light Orange, Coral Red

        // 2. Recipe Distribution (Doughnut)
        var catGroups = recipes.GroupBy(r => r.Category?.Name ?? "Other")
                              .Select(g => new { Name = g.Key, Count = g.Count() }).ToList();
        
        var catColors = catGroups.Select(g => g.Name switch {
            "breakfast" => "#FF6B35",
            "lunch" => "#1E90FF",
            "dinner" => "#FF69B4",
            "dessert" => "#F39C12",
            _ => "#9B59B6"
        }).ToArray();

        await JS.InvokeVoidAsync("renderChart", "categoryPie", "doughnut", 
            catGroups.Select(g => g.Name).ToArray(), 
            catGroups.Select(g => g.Count).ToArray(), "Recipes", catColors);

        // 3. Type of Cuisine (Bar)
        var cuisineGroups = recipes.GroupBy(r => r.TypeCuisine?.Name ?? "Other")
                                 .Select(g => new { Name = g.Key, Count = g.Count() }).ToList();
        await JS.InvokeVoidAsync("renderChart", "cuisineBar", "bar", 
            cuisineGroups.Select(g => g.Name).ToArray(), 
            cuisineGroups.Select(g => g.Count).ToArray(), "Recipes", 
            new[] { "#FF6B35" }); 

        // 4. Average Calories per Category (Line)
        var avgCalsCat = recipes.GroupBy(r => r.Category?.Name ?? "Other")
                               .Select(g => new { Name = g.Key, Avg = g.Average(r => r.CaloriesPerPerson) }).ToList();
        await JS.InvokeVoidAsync("renderChart", "categoryLine", "line", 
            avgCalsCat.Select(g => g.Name).ToArray(), 
            avgCalsCat.Select(g => g.Avg).ToArray(), "Avg kcal", 
            new[] { "#FF6B35" }); 
    }
}