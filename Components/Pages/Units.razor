@page "/units"
@rendermode InteractiveServer
@inject IUnitService UnitService

<div class="page-header">
    <div>
        <h1>Units</h1>
        <p class="subtitle">Manage measurement units for ingredients</p>
    </div>
    <button class="btn btn-primary" @onclick="ShowAddModal">
        <i class="fas fa-plus"></i> Add Unit
    </button>
</div>

@if (units == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Abbreviation</th>
                    <th style="width:120px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var unit in units)
                {
                    <tr>
                        <td>@unit.Id</td>
                        <td>@unit.Name</td>
                        <td><span class="badge time">@unit.Abbreviation</span></td>
                        <td>
                            <div class="card-actions">
                                <button class="btn btn-info btn-icon btn-sm" @onclick="() => ShowEditModal(unit)">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-danger btn-icon btn-sm" @onclick="() => DeleteUnit(unit.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (isModalOpen)
{
    <div class="modal-overlay">
        <div class="modal">
            <h2>@(editingUnit.Id == 0 ? "Add Unit" : "Edit Unit")</h2>
            
            <EditForm Model="editingUnit" OnValidSubmit="SaveUnit">
                <DataAnnotationsValidator />
                
                <div class="form-group">
                    <label>Name</label>
                    <InputText @bind-Value="editingUnit.Name" placeholder="e.g. Grams" />
                    <ValidationMessage For="@(() => editingUnit.Name)" class="validation-message" />
                </div>
                
                <div class="form-group">
                    <label>Abbreviation</label>
                    <InputText @bind-Value="editingUnit.Abbreviation" placeholder="e.g. g" />
                    <ValidationMessage For="@(() => editingUnit.Abbreviation)" class="validation-message" />
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Unit> units;
    private Unit editingUnit = new();
    private bool isModalOpen = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadUnits();
    }

    private async Task LoadUnits()
    {
        units = await UnitService.GetAllAsync();
    }

    private void ShowAddModal()
    {
        editingUnit = new Unit();
        isModalOpen = true;
    }

    private void ShowEditModal(Unit unit)
    {
        editingUnit = new Unit
        {
            Id = unit.Id,
            Name = unit.Name,
            Abbreviation = unit.Abbreviation
        };
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
    }

    private async Task SaveUnit()
    {
        if (editingUnit.Id == 0)
        {
            await UnitService.AddAsync(editingUnit);
        }
        else
        {
            await UnitService.UpdateAsync(editingUnit);
        }
        
        isModalOpen = false;
        await LoadUnits();
    }

    private async Task DeleteUnit(int id)
    {
        // In a real app we might want a confirmation dialog here
        await UnitService.DeleteAsync(id);
        await LoadUnits();
    }
}
